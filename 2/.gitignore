# Python cache
__pycache__/
*.pyc

# Generated run outputs (annotated videos / CSVs / plots)
runs/*.mp4
runs/*.csv
runs/*.png
!runs/.gitkeep

# Large model weights — regenerate via models/export_places365_onnx.py
models/*.onnx
models/*.pth.tar

# Large/generated test videos — regenerate via test_inputs/gen_*.py
# (the small ground-truth CSVs are kept for reproducible acceptance tests)
test_inputs/*.mp4

# Downloaded public datasets (TUM RGB-D, Places365, York Urban DB) — on demand
test_inputs/tum/
test_inputs/places365_val/
test_inputs/yud/
